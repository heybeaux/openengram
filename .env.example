# ═══════════════════════════════════════════════════════════════
# Engram Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Edition ───────────────────────────────────────────────────
# "local" (default) or "cloud"
# EDITION=local

# ── Required (all editions) ──────────────────────────────────
DATABASE_URL=postgresql://engram:engram@postgres:5432/engram
DIRECT_URL=postgresql://engram:engram@postgres:5432/engram

# ── Local Edition ────────────────────────────────────────────
# That's it! docker compose up and go.
# Embeddings run locally by default — no API keys needed.
# EMBEDDING_PROVIDER=local
# PORT=3001

# ── API Key (optional) ──────────────────────────────────────
# Protects your API. Generate any random string.
# AM_API_KEY=your-api-key-here

# ═══════════════════════════════════════════════════════════════
# Cloud Edition Only (EDITION=cloud)
# ═══════════════════════════════════════════════════════════════

# ── Required for Cloud ───────────────────────────────────────
# ENCRYPTION_KEY=          # 32-byte hex key for cloud-link encryption

# ── Embedding Providers ──────────────────────────────────────
# EMBEDDING_PROVIDER=cloud-ensemble
# OPENAI_API_KEY=sk-...
# COHERE_API_KEY=...       # optional, adds cohere-v3 model

# ── Stripe Billing ──────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...

# ── Analytics ────────────────────────────────────────────────
# POSTHOG_API_KEY=phc_...
# GA4_MEASUREMENT_ID=G-...

# ── Dream Cycle v2 Configuration ──────────────────────────────
# DREAM_CYCLE_ENABLED=true                # Enable/disable nightly dream cycle
# DREAM_CYCLE_TZ=UTC                      # Timezone for scheduled runs
# DREAM_MAX_LLM_CALLS=50                  # Maximum LLM calls per dream cycle run
# DREAM_GENERATE_CONTEXT=false            # Generate context files during dream cycle
# DREAM_CONTEXT_WRITE_PATH=               # Path to write generated context files
# DREAM_CONTEXT_AGENT_ID=                 # Agent ID for context generation

# ── Dream Cycle Stage Configuration ───────────────────────────
# DREAM_DEDUP_THRESHOLD=0.85              # Semantic similarity threshold for deduplication
# DREAM_MAX_MERGES=200                    # Maximum memory merges per dream cycle
# DREAM_MAX_ARCHIVALS=100                 # Maximum memories to archive per cycle
# DREAM_STALENESS_DAYS=21                 # Days before memories become stale
# DREAM_STALENESS_SCORE=0.35              # Minimum score to avoid staleness archival
# DREAM_PATTERN_MIN_SIZE=3                # Minimum cluster size for pattern extraction
# DREAM_IDENTITY_MAX_MEMORIES=100         # Maximum memories to process for identity consolidation

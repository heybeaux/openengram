DATABASE_URL=postgresql://engram:engram@postgres:5432/engram
NODE_ENV=production
PORT=3001
AM_API_KEY=your-api-key-here
EMBEDDING_PROVIDER=local
EMBED_SERVICE_URL=http://engram-embed:8080
# Or use OpenAI (single model):
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Or use Cloud Ensemble (multi-model, for Railway/hosted):
# EMBEDDING_PROVIDER=cloud-ensemble
# ENSEMBLE_ENABLED=true
# ENSEMBLE_MODELS=openai-small,openai-large,cohere-v3
# OPENAI_API_KEY=sk-...
# COHERE_API_KEY=...  (optional, adds cohere-v3 model)

# Set to false for production/hosted deployments behind a reverse proxy
TRUST_LOCAL_NETWORK=true

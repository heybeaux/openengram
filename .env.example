# =============================================================================
# Engram — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# Database (required)
# =============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/engram?schema=public"

# =============================================================================
# Vector Storage
# =============================================================================
# Options: pgvector, pinecone (default: pgvector)
VECTOR_PROVIDER="pgvector"

# Pinecone (only if VECTOR_PROVIDER=pinecone)
PINECONE_API_KEY=""
PINECONE_INDEX="engram"

# =============================================================================
# LLM Configuration
# =============================================================================
# Chat/extraction provider: openai, anthropic, ollama, lmstudio
LLM_PROVIDER="openai"
LLM_MODEL="gpt-4o-mini"

# Embedding provider: openai, ollama, local
# local = engram-embed server (768-dim bge-base-en-v1.5, free, ~10ms)
EMBEDDING_PROVIDER="openai"

# =============================================================================
# API Keys (required for chosen providers)
# =============================================================================
# OpenAI (required if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY="sk-..."

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# =============================================================================
# Local Provider URLs (optional, shown with defaults)
# =============================================================================
# Local embedding server (engram-embed)
# Start: cd ~/projects/engram-embed && cargo run --release
LOCAL_EMBED_URL="http://127.0.0.1:8080"

# Ollama (default: http://localhost:11434)
OLLAMA_URL="http://localhost:11434"

# LM Studio (default: http://localhost:1234/v1)
LMSTUDIO_URL="http://localhost:1234/v1"

# =============================================================================
# Server
# =============================================================================
PORT=3000
NODE_ENV=development

# =============================================================================
# Semantic Memory Graph
# =============================================================================
GRAPH_ENABLED=true
GRAPH_EXTRACTION_TIMEOUT_MS=30000

# =============================================================================
# Ensemble Embedding (multi-model fusion)
# =============================================================================
ENSEMBLE_ENABLED=false
ENSEMBLE_REEMBED_ENABLED=false
ENSEMBLE_MODELS=bge-base,minilm,nomic,gte-base
ENSEMBLE_CONSENSUS_BOOST=true
ENSEMBLE_CONSENSUS_FACTOR=0.15

# =============================================================================
# Re-embedding
# =============================================================================
REEMBEDDING_ENABLED=false

# =============================================================================
# Multi-Query Retrieval
# =============================================================================
MULTI_QUERY_ENABLED=false
MULTI_QUERY_LLM_ENABLED=false
MULTI_QUERY_STRATEGY=synonym
MULTI_QUERY_MAX_VARIANTS=3

# =============================================================================
# Search Features
# =============================================================================
PREFETCH_ENABLED=false
DEDUP_ENABLED=false

# =============================================================================
# Summarization
# =============================================================================
SUMMARIZATION_ENABLED=false
SUMMARIZATION_BATCH_SIZE=10

# =============================================================================
# Hierarchy
# =============================================================================
HIERARCHY_ENABLED=false

# =============================================================================
# Dream Cycle (consolidation)
# =============================================================================
DEFAULT_USER_ID=""
EVAL_USER_ID=""
DREAM_MAX_LLM_CALLS=100
DREAM_CONTEXT_AGENT_ID=""

# =============================================================================
# Example Configurations
# =============================================================================
#
# Cloud (OpenAI for everything):
#   LLM_PROVIDER=openai
#   LLM_MODEL=gpt-4o-mini
#   EMBEDDING_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#
# Hybrid (Claude for chat, OpenAI for embeddings):
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-3-5-sonnet-20241022
#   EMBEDDING_PROVIDER=openai
#   ANTHROPIC_API_KEY=sk-ant-...
#   OPENAI_API_KEY=sk-...
#
# Fully Local (Ollama):
#   LLM_PROVIDER=ollama
#   LLM_MODEL=llama3.2
#   EMBEDDING_PROVIDER=ollama
#   # Pull models first: ollama pull llama3.2 && ollama pull nomic-embed-text
#
# Local Embeddings + Cloud LLM:
#   LLM_PROVIDER=openai
#   LLM_MODEL=gpt-4o-mini
#   EMBEDDING_PROVIDER=local
#   LOCAL_EMBED_URL=http://127.0.0.1:8080

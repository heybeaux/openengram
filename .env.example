# Database
DATABASE_URL="postgresql://user:password@localhost:5432/engram?schema=public"

# =============================================================================
# Vector Storage
# =============================================================================
# Choose your vector provider (default: pgvector)
# Options: pgvector, pinecone
VECTOR_PROVIDER="pgvector"

# Pinecone (only if VECTOR_PROVIDER=pinecone)
PINECONE_API_KEY=""
PINECONE_INDEX="engram"

# =============================================================================
# LLM Configuration
# =============================================================================
# Choose your LLM provider for chat/extraction
# Options: openai, anthropic, ollama, lmstudio
LLM_PROVIDER="openai"
LLM_MODEL="gpt-4o-mini"

# Choose your embedding provider
# Options: openai, ollama (anthropic doesn't support embeddings)
EMBEDDING_PROVIDER="openai"

# OpenAI (required if using openai provider)
OPENAI_API_KEY="sk-..."

# Anthropic (required if using anthropic provider)
ANTHROPIC_API_KEY="sk-ant-..."

# Ollama (optional, defaults to localhost:11434)
OLLAMA_URL="http://localhost:11434"

# LM Studio (optional, defaults to localhost:1234/v1)
LMSTUDIO_URL="http://localhost:1234/v1"

# =============================================================================
# Server
# =============================================================================
PORT=3000
NODE_ENV=development

# =============================================================================
# Example Configurations
# =============================================================================
# 
# Cloud (OpenAI for everything):
#   LLM_PROVIDER=openai
#   LLM_MODEL=gpt-4o-mini
#   EMBEDDING_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#
# Hybrid (Claude for chat, OpenAI for embeddings):
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-3-5-sonnet-20241022
#   EMBEDDING_PROVIDER=openai
#   ANTHROPIC_API_KEY=sk-ant-...
#   OPENAI_API_KEY=sk-...
#
# Fully Local (Ollama):
#   LLM_PROVIDER=ollama
#   LLM_MODEL=llama3.2
#   EMBEDDING_PROVIDER=ollama
#   # Pull models first: ollama pull llama3.2 && ollama pull nomic-embed-text
#
# LM Studio:
#   LLM_PROVIDER=lmstudio
#   LLM_MODEL=local-model
#   EMBEDDING_PROVIDER=lmstudio
#   # Load models in LM Studio GUI first

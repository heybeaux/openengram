# Database
DATABASE_URL="postgresql://clawdbot@localhost:5432/engram_code"

# Embedding service
ENGRAM_EMBED_URL="http://127.0.0.1:8080"

# Server
PORT=3002

# LLM (OpenRouter) — used by intent/contracts/gotchas/synthesis passes.
# Required in production; tests use a mock client and don't read this value.
OPENROUTER_API_KEY=""

# Per-repo daily token cap across all LLM passes (EC-22+). Override per-run
# via .engram/config.yaml (EC-27).
EC_DAILY_TOKEN_CAP=500000

# Dashboard (apps/dashboard) — base URL for the v1 API.
EC_API_URL=http://localhost:3000

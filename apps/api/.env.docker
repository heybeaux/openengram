# ===========================================
# Engram Docker Compose Environment Variables
# ===========================================
# Copy to .env and fill in required values:
#   cp .env.docker .env

# --- Required ---
POSTGRES_PASSWORD=changeme

# --- OpenAI (required for LLM features) ---
OPENAI_API_KEY=

# --- Optional overrides ---
# POSTGRES_USER=engram
# PORT=3001
# NODE_ENV=production
# EMBEDDING_PROVIDER=local
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# PINECONE_API_KEY=
# PINECONE_INDEX=engram
# GRAPH_ENABLED=true
# REEMBEDDING_ENABLED=true
# ENSEMBLE_ENABLED=true
# ENSEMBLE_MODELS=bge-base,minilm,nomic,gte-base
# MULTIQUERY_ENABLED=true
# PREFETCH_ENABLED=true
# DEDUP_ENABLED=true

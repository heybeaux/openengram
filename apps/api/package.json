{
  "name": "@openengram/engram",
  "version": "1.5.0",
  "description": "Persistent memory infrastructure for AI agents: semantic, temporal, type-aware, self-hostable, and production-ready.",
  "author": "Beaux Walton",
  "private": false,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest --forceExit --detectOpenHandles --maxWorkers=2",
    "test:watch": "jest --watch --maxWorkers=2",
    "test:cov": "jest --coverage --forceExit --maxWorkers=2",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --forceExit --maxWorkers=2",
    "migrate:safe": "./scripts/safe-migrate.sh migrate deploy",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "premigrate:dev": "echo \"\n\u26a0\ufe0f  WARNING: Use npm run migrate:safe or npm run migrate:deploy instead of prisma migrate dev\n\" && exit 1",
    "seed:staging": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/scripts/seed-staging.ts",
    "api:spec": "pnpm build && node scripts/generate-api-spec.mjs",
    "api:routes": "node scripts/generate-routes.mjs",
    "seed:staging:legacy": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-staging.ts",
    "benchmark": "jest --config ./test/jest-e2e.json --testPathPatterns=recall-benchmark\\.e2e-spec --runInBand --forceExit",
    "benchmark:report": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' test/benchmark/run-benchmark.ts",
    "benchmark:compare": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' -e \"const h = require('./test/benchmark/history'); const c = h.loadLatestReport(); const p = h.loadPreviousReport(); if (c && p) console.log(h.compareReports(c, p)); else console.log('Need at least 2 benchmark runs to compare');\"",
    "benchmark:precompute": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' test/benchmark/harness/precompute.ts",
    "benchmark:sim": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' test/benchmark/harness/simulate.ts",
    "benchmark:sweep": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' test/benchmark/harness/sweep.ts",
    "benchmark:autoresearch": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' test/benchmark/harness/autoresearch-sweep.ts",
    "autoresearch-recall": "npx ts-node scripts/autoresearch-recall.ts",
    "autoresearch-generation": "npx ts-node scripts/autoresearch-insight-generation.ts",
    "autoresearch-boost": "npx ts-node scripts/autoresearch-insight-boost.ts",
    "autoresearch-surfacing": "npx ts-node scripts/autoresearch-insight-surfacing.ts",
    "longmemeval": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' eval/longmemeval/src/runner.ts",
    "longmemeval:test": "jest --config eval/longmemeval/jest.config.json --forceExit",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@elastic/elasticsearch": "8",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@pinecone-database/pinecone": "^7.1.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@sentry/nestjs": "^10.43.0",
    "@sentry/node": "^10.43.0",
    "@types/body-parser": "^1.19.6",
    "@types/cron": "^2.4.3",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cohere-ai": "^7.20.0",
    "cron": "^4.4.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.2",
    "openai": "^6.29.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.3",
    "rxjs": "^7.8.2",
    "stripe": "^20.4.1",
    "svix": "^1.88.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.\\.?/.+)\\.js$": "$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/test-setup.ts"
    ]
  },
  "homepage": "https://github.com/heybeaux/engram#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heybeaux/engram.git"
  },
  "bugs": {
    "url": "https://github.com/heybeaux/engram/issues"
  },
  "keywords": [
    "ai",
    "agent-memory",
    "memory",
    "semantic-search",
    "temporal-reasoning",
    "retrieval",
    "nestjs",
    "pgvector",
    "self-hosted",
    "mcp"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.js.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.security.spec.js",
    "!dist/**/*.security.spec.js.map",
    "!dist/**/*.tsbuildinfo",
    "prisma/schema.prisma",
    "prisma/migrations/**/*",
    "public/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs/API.md",
    "docs/SELF_HOSTING.md",
    "docs/getting-started.md",
    "docs/SDK.md",
    "docker-compose.yml",
    "docker-entrypoint.sh"
  ]
}

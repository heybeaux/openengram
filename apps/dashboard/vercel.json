{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm --filter dashboard build",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "devCommand": "pnpm --filter dashboard dev",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- apps/dashboard/ pnpm-lock.yaml pnpm-workspace.yaml"
}

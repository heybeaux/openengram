{
  "name": "openengram",
  "version": "0.0.0",
  "private": true,
  "description": "OpenEngram platform monorepo",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test:contracts": "pnpm --filter @openengram/contracts build && node --test e2e/contract/*.test.mjs"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "overrides": {
      "@prisma/client": "7.5.0",
      "@prisma/adapter-pg": "7.5.0",
      "prisma": "7.5.0",
      "jest": "30.4.2",
      "@jest/globals": "30.4.1",
      "@types/jest": "30.0.0",
      "ts-jest": "29.4.11"
    }
  }
}

/// Persistent capability profile for an agent — a living document updated with each task outcome
model AgentCapabilityProfile {
  id      String @id @default(cuid())
  agentId String @map("agent_id")
  userId  String @map("user_id")

  /// Capability name (e.g., "code_review", "data_analysis", "writing")
  capability    String
  /// Confidence level 0.0-1.0 based on aggregated evidence
  confidence    Float     @default(0.5)
  /// Number of task outcomes that contributed evidence
  evidenceCount Int       @default(0) @map("evidence_count")
  /// Success rate for tasks using this capability (0.0-1.0)
  successRate   Float     @default(0.0) @map("success_rate")
  /// Average duration for tasks using this capability (ms)
  avgDurationMs Float?    @map("avg_duration_ms")
  /// Last observed usage
  lastUsedAt    DateTime? @map("last_used_at")
  /// Freeform notes aggregated from lessons learned
  notes         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([agentId, userId, capability])
  @@index([agentId, userId])
  @@map("agent_capability_profiles")
}

/// Tracks agent work style patterns extracted from behavioral data
model AgentWorkStyle {
  id      String @id @default(cuid())
  agentId String @map("agent_id")
  userId  String @map("user_id")

  /// Style dimension (e.g., "response_time", "verbosity", "tool_usage", "collaboration_style")
  dimension   String
  /// Current observed value (JSON-encoded for flexibility)
  value       Json
  /// Number of observations
  sampleCount Int     @default(0) @map("sample_count")
  /// Trend direction: improving, stable, declining
  trend       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([agentId, userId, dimension])
  @@index([agentId, userId])
  @@map("agent_work_styles")
}

/// Tracks observation state for each signal source in the Waking Cycle
model AwarenessState {
  id            String   @id @default(cuid())
  accountId     String   @map("account_id")
  signalSource  String   @map("signal_source") // "memory", "github", "linear"
  lastCheckedAt DateTime @map("last_checked_at")
  checkpoint    Json? // source-specific cursor/state (e.g., last memory ID processed)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, signalSource])
  @@map("awareness_states")
}

/// Dream Cycle consolidation reports
model DreamCycleReport {
  id     String @id @default(cuid())
  userId String @map("user_id")

  startedAt   DateTime  @map("started_at")
  completedAt DateTime? @map("completed_at")
  durationMs  Int?      @map("duration_ms")
  dryRun      Boolean   @default(false) @map("dry_run")

  // Stage results
  scoresRefreshed  Int @default(0) @map("scores_refreshed")
  duplicatesMerged Int @default(0) @map("duplicates_merged")
  patternsCreated  Int @default(0) @map("patterns_created")
  memoriesArchived Int @default(0) @map("memories_archived")

  // Health metrics
  totalActive       Int   @default(0) @map("total_active")
  avgEffectiveScore Float @default(0) @map("avg_effective_score")

  // Details
  stageDetails Json     @default("{}") @map("stage_details")
  errors       String[] @default([])
  status       String   @default("RUNNING")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("dream_cycle_reports")
}

/// HEY-176: Identity snapshots produced by Dream Cycle identity consolidation
model IdentitySnapshot {
  id      String  @id @default(cuid())
  userId  String  @map("user_id")
  agentId String? @map("agent_id")

  /// Structured identity data
  capabilities     Json @default("[]") // Array of { name, confidence, lastSeen }
  preferences      Json @default("{}") // Key-value preference summary
  trustScores      Json @default("{}") // { source: score } trends
  behavioralTraits Json @default("[]") @map("behavioral_traits") // Array of { trait, strength, evidence }

  /// Source tracking
  sourceMemoryIds String[] @default([]) @map("source_memory_ids")
  dreamReportId   String?  @map("dream_report_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([agentId, createdAt])
  @@map("identity_snapshots")
}

/// Tracks Dream Cycle execution runs for mutex / concurrency control
model DreamCycleRun {
  id         String    @id @default(cuid())
  status     String    @default("RUNNING") // RUNNING | COMPLETED | FAILED
  instanceId String    @map("instance_id") // hostname or unique instance identifier
  startedAt  DateTime  @default(now()) @map("started_at")
  endedAt    DateTime? @map("ended_at")
  error      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("dream_cycle_runs")
}

/// Eval run results for longitudinal tracking
model EvalRun {

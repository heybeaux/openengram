/// Instance Sync Key — authenticates a local instance for cloud sync.
/// Account-level (not agent-level). Does NOT create agent identity.
model InstanceSyncKey {
  id           String    @id @default(cuid())
  accountId    String    @map("account_id")
  keyHash      String    @unique @map("key_hash")
  keyHint      String    @map("key_hint")
  instanceName String    @map("instance_name")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime? @map("last_used_at")
  revokedAt    DateTime? @map("revoked_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("instance_sync_keys")
}

/// Maps local agentId to cloud agentId per sync instance
model SyncAgentMap {
  id           String   @id @default(cuid())
  instanceId   String   @map("instance_id")
  localAgentId String   @map("local_agent_id")
  cloudAgentId String   @map("cloud_agent_id")
  agentName    String   @map("agent_name")
  createdAt    DateTime @default(now()) @map("created_at")

  cloudAgent Agent @relation(fields: [cloudAgentId], references: [id], onDelete: Cascade)

  @@unique([instanceId, localAgentId])
  @@unique([instanceId, agentName])
  @@index([cloudAgentId])
  @@map("sync_agent_map")
}

/// Maps local userId to cloud userId per sync instance
model SyncUserMap {
  id          String   @id @default(cuid())
  instanceId  String   @map("instance_id")
  localUserId String   @map("local_user_id")
  cloudUserId String   @map("cloud_user_id")
  externalId  String   @map("external_id")
  createdAt   DateTime @default(now()) @map("created_at")

  cloudUser User @relation(fields: [cloudUserId], references: [id], onDelete: Cascade)

  @@unique([instanceId, localUserId])
  @@unique([instanceId, cloudUserId])
  @@index([cloudUserId])
  @@map("sync_user_map")
}

/// Instance API Key — account-level keys for cloud sync, admin, and account actions.
/// Separate from agent-level API keys. Prefix: eng_inst_
model InstanceApiKey {
  id         String    @id @default(cuid())
  accountId  String    @map("account_id")
  name       String
  keyHash    String    @unique @map("key_hash")
  keyHint    String    @map("key_hint")
  scopes     String[]  @default(["sync", "read"])
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("instance_api_keys")
}

/// Tracks connected local instances on the cloud side
model CloudInstance {
  id            String    @id @default(cuid())
  accountId     String    @map("account_id")
  instanceId    String    @map("instance_id") // The InstanceSyncKey ID or X-Instance-Id header
  instanceName  String?   @map("instance_name")
  lastSyncAt    DateTime? @map("last_sync_at")
  memoryCount   Int       @default(0) @map("memory_count")
  lastPushCount Int       @default(0) @map("last_push_count")
  status        String    @default("active") // active, stale, disconnected
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([accountId, instanceId])
  @@index([accountId])
  @@map("cloud_instances")
}

// ============================================================================
// IDENTITY SIGNALS (HEY-170, HEY-172, HEY-173)
// ============================================================================

/// Trust signals extracted from agent behavior (HEY-170)
model TrustSignal {
  id             String          @id @default(cuid())
  userId         String          @map("user_id")
  agentId        String?         @map("agent_id")
  signalType     TrustSignalType @map("signal_type")
  context        String // Description of what happened
  category       String? // Task category (e.g., "deploy", "code-review")
  weight         Float           @default(1.0) // Signal strength 0.0-2.0
  sourceMemoryId String?         @map("source_memory_id")
  metadata       Json?           @map("metadata")
  createdAt      DateTime        @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([userId, category])
  @@index([userId, signalType])
  @@index([agentId, createdAt])
  @@map("trust_signals")
}

enum TrustSignalType {
  SUCCESS
  FAILURE
  CORRECTION
}

/// Trust score snapshots computed from accumulated signals (HEY-170)
model TrustScore {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  agentId         String?  @map("agent_id")
  category        String? // null = overall score
  score           Float // 0.0-1.0
  signalCount     Int      @default(0) @map("signal_count")
  successCount    Int      @default(0) @map("success_count")
  failureCount    Int      @default(0) @map("failure_count")
  correctionCount Int      @default(0) @map("correction_count")
  computedAt      DateTime @default(now()) @map("computed_at")

  @@index([userId, category])
  @@index([userId, computedAt])
  @@index([agentId, category])
  @@map("trust_scores")
}

/// Capability checkpoints for tracking agent growth (HEY-172)
model CapabilityCheckpoint {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  agentId      String?  @map("agent_id")
  capabilities Json // Array of { name, evidenceCount, firstSeen, lastSeen }
  checkpointAt DateTime @default(now()) @map("checkpoint_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, checkpointAt])
  @@index([agentId, checkpointAt])
  @@map("capability_checkpoints")
}

/// Experience weight per task category for recall boosting (HEY-173)
model ExperienceWeight {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  agentId      String?  @map("agent_id")
  category     String // Task category (e.g., "deploy", "code-review")
  successCount Int      @default(0) @map("success_count")
  totalCount   Int      @default(0) @map("total_count")
  weight       Float    @default(1.0) // Computed multiplier for recall
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([userId, agentId, category])
  @@index([userId, weight(sort: Desc)])
  @@map("experience_weights")
}

// ============================================================================
// MULTI-AGENT TEAMS (HEY-188)
// ============================================================================

/// Team of agents with shared context and collaboration history
model AgentTeam {
  id                 String    @id @default(cuid())
  name               String
  description        String?
  userId             String    @map("user_id")
  sharedCapabilities String[]  @default([]) @map("shared_capabilities")
  trustScore         Float     @default(0) @map("trust_score")
  collaborationCount Int       @default(0) @map("collaboration_count")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  members        AgentTeamMember[]
  collaborations AgentTeamCollaboration[]

  @@index([userId])
  @@map("agent_teams")
}

/// Membership of an agent in a team
model AgentTeamMember {
  id       String   @id @default(cuid())
  teamId   String   @map("team_id")
  agentId  String   @map("agent_id")
  role     String?
  joinedAt DateTime @default(now()) @map("joined_at")

  team AgentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, agentId])
  @@index([agentId])
  @@map("agent_team_members")
}

/// Record of agents collaborating on a task within a team
model AgentTeamCollaboration {
  id                  String   @id @default(cuid())
  teamId              String   @map("team_id")
  taskDescription     String   @map("task_description")
  participantAgentIds String[] @map("participant_agent_ids")
  outcome             String?
  score               Float?
  createdAt           DateTime @default(now()) @map("created_at")

  team AgentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@map("agent_team_collaborations")
}

/// Tracks sync events for history display
model SyncEvent {
  id           String   @id @default(cuid())
  accountId    String   @map("account_id")
  direction    String   @default("push") // push, pull
  status       String   @default("completed") // completed, failed, cancelled
  totalCount   Int      @default(0) @map("total_count")
  newCount     Int      @default(0) @map("new_count")
  updatedCount Int      @default(0) @map("updated_count")
  skippedCount Int      @default(0) @map("skipped_count")
  failedCount  Int      @default(0) @map("failed_count")
  error        String?
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([accountId, createdAt])
  @@map("sync_events")
}

/// Maps local memory IDs to cloud memory IDs for sync tracking
model SyncIdMap {
  id            String   @id @default(cuid())
  localMemoryId String   @map("local_memory_id")
  cloudMemoryId String   @map("cloud_memory_id")
  instanceId    String   @map("instance_id")
  contentHash   String?  @map("content_hash")
  syncedAt      DateTime @default(now()) @map("synced_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([instanceId, localMemoryId])
  @@unique([instanceId, cloudMemoryId])
  @@index([contentHash])
  @@map("sync_id_map")
}

/// Task completion records for identity framework delegation tracking
model TaskCompletion {
  id              String                 @id @default(cuid())
  taskId          String                 @map("task_id")
  delegatedTo     String                 @map("delegated_to")
  delegatedBy     String                 @map("delegated_by")
  taskDescription String                 @map("task_description")
  domain          String?
  outcome         String // success, failure, partial
  durationMs      Int                    @map("duration_ms")
  qualitySignals  Json                   @default("{}") @map("quality_signals")
  metadata        Json                   @default("{}")
  embeddingText   String?                @map("embedding_text")
  embedding       Unsupported("vector")?
  createdAt       DateTime               @default(now()) @map("created_at")

  @@index([delegatedTo])
  @@index([delegatedBy])
  @@index([taskId])
  @@index([domain])
  @@index([createdAt])
  @@map("task_completions")
}

// ============================================================================
// DELEGATION (HEY-182, HEY-183, HEY-185)
// ============================================================================

/// Task status lifecycle for delegation tracking (HEY-182)
enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  FAILED
}

/// Delegated task tracked through its lifecycle (HEY-182)
model DelegatedTask {
  id              String     @id @default(cuid())
  userId          String     @map("user_id")
  assignedTo      String     @map("assigned_to")
  assignedBy      String     @map("assigned_by")
  taskDescription String     @map("task_description")
  status          TaskStatus @default(ASSIGNED)
  deadline        DateTime?
  completedAt     DateTime?  @map("completed_at")
  result          String?
  metadata        Json?
  memoryId        String?    @map("memory_id") // Link to memory storing this task
  templateId      String?    @map("template_id")
  contractId      String?    @map("contract_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  template DelegationTemplate? @relation(fields: [templateId], references: [id])
  contract DelegationContract? @relation(fields: [contractId], references: [id])

  @@index([userId, status])
  @@index([assignedTo, status])
  @@index([assignedBy])
  @@index([contractId])
  @@map("delegated_tasks")
}

/// Reusable delegation template (HEY-183)
model DelegationTemplate {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  name                 String
  taskType             String   @map("task_type")
  requiredCapabilities String[] @default([]) @map("required_capabilities")
  defaultInstructions  String?  @map("default_instructions")
  expectedOutputs      String?  @map("expected_outputs")
  typicalDurationMs    Int?     @map("typical_duration_ms")
  metadata             Json?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tasks DelegatedTask[]

  @@unique([userId, name])
  @@index([userId, taskType])
  @@map("delegation_templates")
}

/// Contract status lifecycle (HEY-185)
enum ContractStatus {
  PROPOSED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  VERIFIED
  REJECTED
}

/// Formal delegation contract between agents (HEY-185)
model DelegationContract {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  delegator       String
  delegate        String
  taskDescription String         @map("task_description")
  status          ContractStatus @default(PROPOSED)
  terms           Json // { deadline, qualityCriteria, escalationRules }
  result          String?
  verifiedAt      DateTime?      @map("verified_at")
  completedAt     DateTime?      @map("completed_at")
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  tasks DelegatedTask[]

  @@index([userId, status])
  @@index([delegator])
  @@index([delegate])
  @@map("delegation_contracts")
}

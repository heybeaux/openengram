  score      Float
  tier       String
  components Json?    @db.JsonB
  computedAt DateTime @default(now()) @map("computed_at")

  @@index([computedAt])
  @@map("fog_index_snapshots")
}

/// Monitoring metric snapshots for tracking system health over time
model MonitoringSnapshot {
  id         String   @id @default(cuid())
  metrics    Json     @default("{}")
  alerts     Json     @default("[]")
  snapshotAt DateTime @default(now()) @map("snapshot_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([snapshotAt])
  @@map("monitoring_snapshots")
}

/// Cloud link for self-hosted instances connecting to OpenEngram Cloud
model CloudLink {
  id             String    @id @default(cuid())
  accountId      String    @unique @map("account_id")
  instanceId     String?   @map("instance_id") // UUID identifying this self-hosted instance for dedup
  cloudApiKey    String    @map("cloud_api_key") // encrypted instance API key for auth
  cloudSyncKey   String?   @map("cloud_sync_key") // encrypted esync_ key for sync push
  cloudAccountId String?   @map("cloud_account_id")
  cloudEmail     String?   @map("cloud_email")
  cloudPlan      String?   @map("cloud_plan")
  lastVerifiedAt DateTime? @map("last_verified_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  autoSync     Boolean   @default(false) @map("auto_sync")
  lastPulledAt DateTime? @map("last_pulled_at")

